                kehilangan paling menyakitkan adalah ketika kesempatan itu hanya bisa dikenang, 
                bukan diulang."<p>
        </div>
    </section>
<script>
const hero = document.querySelector(".Pembukaan");

for(let i=0;i<25;i++){
  const leaf = document.createElement("div");
  leaf.classList.add("Daunsurgawi");

  leaf.style.left = Math.random() * 100 + "vw";
  leaf.style.animationDuration = 5 + Math.random() * 5 + "s";
  leaf.style.animationDelay = Math.random() * 5 + "s";

  hero.appendChild(leaf);
}
</script>
