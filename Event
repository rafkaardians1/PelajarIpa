<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:sans-serif;
}

body{
  overflow-x:hidden;
}
.Pembukaan{
  height:95vh;
  background:url('PelajarIpaFoto/EVENT\ IPA.png') center/cover no-repeat;
  position: relative;
  display:flex;
  align-items:center;
  padding-left: 5% ;
  color:white;
  overflow:hidden;
}
.Pembukaan::after{
  content:'';
  position:absolute;
  inset:0;
  background:rgba(0,0,0,0.3);
}
.Pembukaan-content{
  position:relative;
  z-index:2;
  max-width:500px;
}
.Pembukaan p {
    font-size: 25px;
}
.Daunsurgawi{
  position:absolute;
  top: 0px;
  width:20px;
  height:20px;
  background:linear-gradient(45deg,#4CAF50,#2e7d32);
  border-radius:50% 0 50% 0;
  opacity:0.9;
  animation:fall linear infinite;
  z-index:1;
}
@keyframes fall{
  0%{
    transform:translate(0,-50px) rotate(0deg);
  }
  50%{
    transform:translate(40px,50vh) rotate(180deg);
  }
  100%{
    transform:translate(-40px,110vh) rotate(360deg);
  }
}
.section{
  padding:100px 10%;
  text-align:center;
}
.section h2{
  font-size:2rem;
  margin-bottom:30px;
}
    </style>
</head>
